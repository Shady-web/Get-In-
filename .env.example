# Copy this file to ".env" and fill it in before running: npm run setup:txline

# Which network to use: "devnet" (free, fake SOL from a faucet) or "mainnet".
NETWORK=devnet

# --- Optional overrides (safe to leave commented out) ---

# Use a custom Solana RPC instead of the public one (recommended for mainnet).
# SOLANA_RPC_URL=

# Where to store the generated keypair (gitignored by default).
# KEYPAIR_PATH=.txline-keypair.json

# Subscription length in weeks (48 = ~12 months). Free tier, so longer is fine.
# DURATION_WEEKS=48


# ----------------------------------------------------------------------------
# The setup script PRINTS these when it succeeds. Put them in .env.local
# (server-only) for your Next.js API routes - never expose them to the browser.
# ----------------------------------------------------------------------------
# TXLINE_NETWORK=devnet
# TXLINE_API_TOKEN=
# TXLINE_API_BASE=https://txline-dev.txodds.com/api

# Supabase (server-only; from Project Settings -> API). Also .env.local.
# Run supabase/schema.sql in the Supabase SQL editor once.
# SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=

# REQUIRED for sign-in (email/password, username, Google) AND the realtime
# leaderboard. The PUBLIC anon key is browser-safe. Enable the Email and
# Google providers in Supabase Dashboard -> Authentication -> Providers.
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Optional: custom Solana devnet RPC for custodial wallet balances.
# SOLANA_RPC_URL=https://api.devnet.solana.com

# Optional: pin real finished matches to the top of Replay Mode (comma-
# separated fixture ids). Browser-safe, so NEXT_PUBLIC_. Leave unset to show
# the bundled demo France–Spain replay. After the real France–Spain is played,
# find its FixtureId (GET /api/worldcup, look for the finished France v Spain)
# and set it here, then redeploy: the real replay takes over and the demo is
# hidden automatically. Until a pinned match is actually finished, the demo
# stays so Replay Mode is never empty.
# NEXT_PUBLIC_PINNED_REPLAY_IDS=123456

# Devnet HOUSE float — pays every user withdrawal (server-signed) so
# coin-converted SOL winnings can be cashed out. Create it once with
# `npm run setup:house`, fund the printed address from the faucet, then paste
# the printed secret here (server-only; NEVER prefix with NEXT_PUBLIC_).
# HOUSE_WALLET_SECRET=[12,34,...]
# Warn in the server logs when the float drops below this many SOL (default 1).
# HOUSE_LOW_SOL=1

# Optional: Pundit ticker AI takes (Google AI Studio free tier).
# Get a free key at https://aistudio.google.com (Get API key). Server-only,
# goes in .env.local; the ticker hides itself when this is unset.
# Requires running supabase/schema-v6.sql for the cross-replay take cache.
# GEMINI_API_KEY=
