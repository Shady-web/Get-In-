# Copy this file to ".env" and fill it in before running: npm run setup:txline

# Which network to use: "devnet" (free, fake SOL from a faucet) or "mainnet".
NETWORK=devnet

# --- Optional overrides (safe to leave commented out) ---

# Use a custom Solana RPC instead of the public one (recommended for mainnet).
# SOLANA_RPC_URL=

# Where to store the generated keypair (gitignored by default).
# KEYPAIR_PATH=.txline-keypair.json

# Subscription length in weeks (48 = ~12 months). Free tier, so longer is fine.
# DURATION_WEEKS=48


# ----------------------------------------------------------------------------
# The setup script PRINTS these when it succeeds. Put them in .env.local
# (server-only) for your Next.js API routes - never expose them to the browser.
# ----------------------------------------------------------------------------
# TXLINE_NETWORK=devnet
# TXLINE_API_TOKEN=
# TXLINE_API_BASE=https://txline-dev.txodds.com/api

# Supabase (server-only; from Project Settings -> API). Also .env.local.
# Run supabase/schema.sql in the Supabase SQL editor once.
# SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=

# Optional: live leaderboard via Supabase Realtime in the browser.
# Uses the PUBLIC anon key (safe for browsers; players table is read-only).
# Requires running supabase/schema-v2.sql first. Falls back to polling if unset.
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Optional: Pundit ticker AI takes (Google AI Studio free tier).
# Get a free key at https://aistudio.google.com (Get API key). Server-only,
# goes in .env.local; the ticker hides itself when this is unset.
# Requires running supabase/schema-v6.sql for the cross-replay take cache.
# GEMINI_API_KEY=
